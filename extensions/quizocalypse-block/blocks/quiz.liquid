{% comment %}
  Quizocalypse Quiz — App Block.
  Renders the merchant's published quiz inline via iframe.
  Configure Quiz ID + App URL in the theme editor.
{% endcomment %}

{%- assign clean_url = block.settings.app_url | strip | replace: ' ', '' -%}
{%- assign quiz_id = block.settings.quiz_id | strip -%}

<div class="quizocalypse-block" {{ block.shopify_attributes }}>
  {%- if quiz_id != blank and clean_url != blank -%}
    <iframe
      src="{{ clean_url }}/q/{{ quiz_id }}?locale={{ request.locale.iso_code }}"
      title="{{ block.settings.iframe_title | default: 'Product finder quiz' }}"
      loading="lazy"
      allow="clipboard-write"
      style="display:block;width:100%;border:0;min-height:{{ block.settings.min_height | default: 720 }}px;background:transparent;"
    ></iframe>
    <script>
      // In-Quiz Add-On: the quiz iframe (cross-origin) can't call the AJAX cart
      // itself, so it posts a "qz:add-to-cart" message; we add same-origin via
      // /cart/add.js, ack back so the quiz stays put, and toast. If we don't ack
      // (e.g. add failed), the quiz falls back to a cart permalink.
      (function () {
        var APP = {{ clean_url | json }};
        var appOrigin = null;
        try { appOrigin = new URL(APP).origin; } catch (e) {}
        function toast(msg) {
          var t = document.createElement("div");
          t.textContent = msg;
          t.setAttribute("role", "status");
          t.setAttribute("aria-live", "polite");
          t.className = "quizocalypse-block__toast";
          document.body.appendChild(t);
          setTimeout(function () { t.remove(); }, 2500);
        }
        window.addEventListener("message", function (e) {
          if (appOrigin && e.origin !== appOrigin) return;
          var d = e.data;
          if (!d || d.type !== "qz:add-to-cart" || !d.variantId) return;
          // Ack on RECEIPT so the quiz cancels its permalink fallback (avoids a
          // double-add if the cart write is slow). Post :fail only if it errors.
          function reply(type) {
            try { e.source && e.source.postMessage({ type: type }, appOrigin || "*"); } catch (_) {}
          }
          reply("qz:add-to-cart:ok");
          fetch("/cart/add.js", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ items: [{ id: Number(d.variantId), quantity: d.quantity || 1 }] }),
          })
            .then(function (r) { if (!r.ok) throw new Error("add failed"); return r.json(); })
            .then(function () {
              try { document.dispatchEvent(new CustomEvent("cart:refresh")); } catch (_) {}
              toast("Added to cart");
            })
            .catch(function () { reply("qz:add-to-cart:fail"); });
        });
      })();
    </script>
  {%- else -%}
    <div class="quizocalypse-block__empty" role="status">
      <strong>Quizocalypse block</strong><br/>
      Open this block's settings in the theme editor and set:<br/>
      <em>Quiz ID</em> (from the Quizocalypse admin) and <em>App URL</em> (your Quizocalypse app's public URL).
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Quizocalypse Quiz",
  "target": "section",
  "stylesheet": "block.css",
  "settings": [
    {
      "type": "header",
      "content": "Quiz source"
    },
    {
      "type": "text",
      "id": "quiz_id",
      "label": "Quiz ID",
      "info": "Open the published quiz in the Quizocalypse admin and copy the ID from the URL (the part after /app/quizzes/)."
    },
    {
      "type": "url",
      "id": "app_url",
      "label": "App URL",
      "info": "The public URL of your Quizocalypse install (e.g. https://your-tunnel.trycloudflare.com in dev, or your production domain)."
    },
    {
      "type": "header",
      "content": "Display"
    },
    {
      "type": "range",
      "id": "min_height",
      "label": "Minimum height",
      "min": 400,
      "max": 1400,
      "step": 20,
      "unit": "px",
      "default": 720
    },
    {
      "type": "text",
      "id": "iframe_title",
      "label": "Accessibility title",
      "default": "Product finder quiz",
      "info": "Used as the iframe's title attribute for screen readers."
    }
  ]
}
{% endschema %}

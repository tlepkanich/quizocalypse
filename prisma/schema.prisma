generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?

  @@index([shop])
}

model Shop {
  id             String    @id @default(cuid())
  shopDomain     String    @unique
  installedAt    DateTime  @default(now())
  scope          String?
  lastSyncAt     DateTime?
  lastSyncStatus String?
  lastSyncError  String?
  brandTokens    Json?
  // Phase 7: structured brand voice guidelines distilled from a brand
  // book / image / text upload, or selected from the curated preset
  // library. See app/lib/brandGuidelines.ts for the schema.
  brandGuidelines Json?
  // Builder Re-work Step 0: the persistent Merchant Brand Identity digest
  // (summary + design lens + positioning lens + voice + provenance). See
  // app/lib/brandIdentity.ts. brandIdentityState is the build poll marker
  // ("building" | "error:<msg>" | null), mirroring Quiz.buildState.
  brandIdentity      Json?
  brandIdentityState String?
  // Spin-off: "shopify" (installed via OAuth) | "standalone" (a non-Shopify
  // workspace, keyed on a synthetic domain like studio.local). Drives whether
  // Shopify-only paths (sync, discounts, brand signals) run. See
  // app/lib/studioAccess.server.ts isStandalone().
  source         String    @default("shopify")

  // Standalone Shopify connector: a non-Shopify (source="standalone") workspace
  // can connect a Shopify store via a custom-app Admin API token to sync its
  // catalog. The token is AES-256-GCM encrypted at rest (app/lib/crypto.ts);
  // the domain is the connected <store>.myshopify.com. Both null when not
  // connected. lastSync* (above) double as the connector's sync status.
  shopifyConnectDomain String?
  shopifyConnectToken  String?
  shopifyConnectedAt   DateTime?

  products       Product[]
  collections    Collection[]
  categories     Category[]
  quizzes        Quiz[]
  savedTemplates SavedTemplate[]
}

// Builder Re-work Step 2: a merchant-saved "battle card" template (a serialized
// RichTemplateOption — design dials, rec defaults, feature notes) reusable on a
// future quiz. See app/lib/savedTemplates.server.ts + app/lib/quizSchema.ts.
model SavedTemplate {
  id        String   @id @default(cuid())
  shopId    String
  name      String
  payload   Json
  createdAt DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
}

model Product {
  productId     String   @id
  shopId        String
  title         String
  handle        String
  vendor        String?
  productType   String?
  status        String?
  tags          String[]
  collectionIds String[]
  variants      Json
  metafields    Json
  imageUrl      String?
  // Spin-off: the merchant's own product URL ("Shop now" click-through for
  // standalone shops, where there's no Shopify cart permalink). Null for synced
  // Shopify products (which build a cart permalink from the variant GID).
  url           String?
  // "shopify" (synced) | "manual" (added by hand / CSV import). Manual rows use
  // platform-neutral man_<cuid> productIds + one synthetic variant.
  source        String   @default("shopify")
  priceMin      Decimal? @db.Decimal(10, 2)
  priceMax      Decimal? @db.Decimal(10, 2)
  // ISO 4217 currency code of the prices above (the shop's Shopify
  // currencyCode, read from priceRangeV2.minVariantPrice during sync). All
  // variants of a Shopify shop share one currency. Null for manually-added
  // products and rows synced before this column existed → the runtime falls
  // back to USD formatting.
  currency      String?
  // Raw HTML body from Shopify (descriptionHtml). Source of truth.
  descriptionHtml String?
  // Stripped plain-text version of descriptionHtml — used as input to the
  // Claude tag enrichment so we don't pay tokens on markup.
  descriptionText String?
  // Last time Claude enriched this product's tags. Null = never. The
  // enrichment batch skips products refreshed in the last 30 days.
  lastEnrichedAt DateTime?
  updatedAt     DateTime @default(now()) @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([shopId, handle])
}

model Collection {
  collectionId String   @id
  shopId       String
  title        String
  handle       String?
  productIds   String[]
  updatedAt    DateTime @default(now()) @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
}

// Auto-discovered shopper archetypes. Distinct from Shopify Collections
// (which mirror live store data) — Categories are admin-internal and
// regenerated on demand by Claude reading the catalog. They power the
// archetype branch of the quiz recommendation engine: a ResultPage with
// match_strategy="archetype" + category_id pulls products from here.
model Category {
  id             String   @id @default(cuid())
  shopId         String
  // Phase 2 builder: when a bucket is created inside a quiz's Step-1 product
  // grouping, it's scoped to that quiz. Null = legacy shop-global bucket
  // (the standalone /app/categories page), kept for back-compat.
  quizId         String?
  name           String
  description    String
  // Embodying tags Claude picked from the catalog vocabulary. Used by
  // categoryAssign to score every product's overlap and bucket it.
  tags           String[]
  // Shopify product IDs (gids) bucketed into this category by the
  // deterministic tag-overlap pass OR a non-AI grouping source. Refreshed
  // every grouping/discovery run.
  productIds     String[]
  // v3 grouping on-ramp: how this group was created.
  // "ai" | "manual" | "collection" | "smart_collection" | "tag" |
  // "product_type" | "metafield". Defaults "ai" for existing rows.
  source         String   @default("ai")
  // The dimension value this group came from (collection id / tag /
  // product type / metafield value). Null for manual + ai.
  sourceRef      String?
  // Explicitly pinned product ids in manual mode (productIds is the
  // resolved set; this is the merchant's hand-picked subset).
  manualProductIds String[]
  // One-sentence rationale Claude wrote — surfaced in the admin tooltip.
  rationale      String?
  // Groups every Category created in a single discovery invocation so
  // we can tell when a set was generated.
  discoveryRunId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([shopId, quizId])
}

model Quiz {
  id            String   @id @default(cuid())
  shopId        String
  name          String
  status        String   @default("draft")
  // Transient async-build marker for AI onboarding: "building" while the
  // detached build runs, "error:<msg>" on failure, null when done/normal.
  // Lets the editor poll an overlay instead of blocking the request (the full
  // AI build outruns the edge proxy's ~60s timeout).
  buildState    String?
  draftJson     Json
  publishedJson Json?
  version       Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  shop     Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  versions QuizVersion[]
  events   Event[]
  captures EmailCapture[]
  sessions QuizSession[]

  @@index([shopId])
}

model QuizVersion {
  id            String   @id @default(cuid())
  quizId        String
  version       Int
  publishedJson Json
  publishedAt   DateTime @default(now())

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@unique([quizId, version])
}

model Event {
  id        String   @id @default(cuid())
  shopId    String?
  quizId    String
  sessionId String
  eventType String
  payload   Json
  ts        DateTime @default(now())

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId, ts])
  @@index([quizId, eventType, ts])
}

model EmailCapture {
  id         String   @id @default(cuid())
  shopId     String?
  quizId     String
  sessionId  String
  email      String
  firstName  String?
  phone      String?
  capturedAt DateTime @default(now())

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId, capturedAt])
  @@index([email])
}

// Server-side quiz session (Dev Spec §7.2). One row per (quizId, sessionId):
// the shopper's answers, the products we matched them to, and the outcome page,
// plus a `converted` flag set later by the order webhook. Powers cross-device
// resume + "My Results" + conversion attribution (follow-on slices).
model QuizSession {
  id                String    @id @default(cuid())
  shopId            String?
  quizId            String
  sessionId         String
  outcomeId         String?
  answerIds         String[]
  matchedProductIds String[]
  converted         Boolean   @default(false)
  startedAt         DateTime  @default(now())
  completedAt       DateTime?

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@unique([quizId, sessionId])
  @@index([quizId, completedAt])
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?

  @@index([shop])
}

model Shop {
  id             String    @id @default(cuid())
  shopDomain     String    @unique
  installedAt    DateTime  @default(now())
  scope          String?
  lastSyncAt     DateTime?
  lastSyncStatus String?
  lastSyncError  String?
  brandTokens    Json?
  // §L — account-level engagement defaults (EngagementSettings shape). Applied
  // to new quizzes; per-quiz `engagement` overrides. Null = use ENGAGEMENT_DEFAULTS.
  engagementDefaults Json?
  // Phase 7: structured brand voice guidelines distilled from a brand
  // book / image / text upload, or selected from the curated preset
  // library. See app/lib/brandGuidelines.ts for the schema.
  brandGuidelines Json?
  // Builder Re-work Step 0: the persistent Merchant Brand Identity digest
  // (summary + design lens + positioning lens + voice + provenance). See
  // app/lib/brandIdentity.ts. brandIdentityState is the build poll marker
  // ("building" | "error:<msg>" | null), mirroring Quiz.buildState.
  brandIdentity      Json?
  brandIdentityState String?
  // Spin-off: "shopify" (installed via OAuth) | "standalone" (a non-Shopify
  // workspace, keyed on a synthetic domain like studio.local). Drives whether
  // Shopify-only paths (sync, discounts, brand signals) run. See
  // app/lib/studioAccess.server.ts isStandalone().
  source         String    @default("shopify")

  // Standalone Shopify connector: a non-Shopify (source="standalone") workspace
  // can connect a Shopify store via a custom-app Admin API token to sync its
  // catalog. The token is AES-256-GCM encrypted at rest (app/lib/crypto.ts);
  // the domain is the connected <store>.myshopify.com. Both null when not
  // connected. lastSync* (above) double as the connector's sync status.
  shopifyConnectDomain String?
  shopifyConnectToken  String?
  shopifyConnectedAt   DateTime?

  // LOGIC v2 L2-12 (owner GO 2026-07-03, "kill switch default on" = feature
  // ENABLED by default): gates ONLY the public per-shopper rec-copy endpoint
  // (q.$id.rec-copy — runtime AI spend on the shopper hot path). Never gates
  // the admin ✦ why-copy generate or the Tier-2 quality review — those are
  // merchant-initiated, visible-error spends.
  aiRecCopyEnabled Boolean @default(true)

  // FAST F1 — cached quiz-strategy web research for the create funnel. Shape:
  // { text: string, positioning_hash: string, at: ISO string } (see
  // app/lib/shopWebResearch.server.ts). The research inputs are SHOP-LEVEL only
  // (brand-identity positioning), so one row serves every draft; freshness is
  // a positioning hash + 24h TTL. Null = never researched (failures are never
  // persisted, so a failed run can't poison the cache).
  webResearch Json?

  products       Product[]
  collections    Collection[]
  categories     Category[]
  quizzes        Quiz[]
  savedTemplates SavedTemplate[]
}

// Builder Re-work Step 2: a merchant-saved "battle card" template (a serialized
// RichTemplateOption — design dials, rec defaults, feature notes) reusable on a
// future quiz. See app/lib/savedTemplates.server.ts + app/lib/quizSchema.ts.
model SavedTemplate {
  id        String   @id @default(cuid())
  shopId    String
  name      String
  payload   Json
  createdAt DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
}

model Product {
  productId     String   @id
  shopId        String
  title         String
  handle        String
  vendor        String?
  productType   String?
  status        String?
  tags          String[]
  collectionIds String[]
  variants      Json
  metafields    Json
  imageUrl      String?
  // Spin-off: the merchant's own product URL ("Shop now" click-through for
  // standalone shops, where there's no Shopify cart permalink). Null for synced
  // Shopify products (which build a cart permalink from the variant GID).
  url           String?
  // "shopify" (synced) | "manual" (added by hand / CSV import). Manual rows use
  // platform-neutral man_<cuid> productIds + one synthetic variant.
  source        String   @default("shopify")
  priceMin      Decimal? @db.Decimal(10, 2)
  priceMax      Decimal? @db.Decimal(10, 2)
  // ISO 4217 currency code of the prices above (the shop's Shopify
  // currencyCode, read from priceRangeV2.minVariantPrice during sync). All
  // variants of a Shopify shop share one currency. Null for manually-added
  // products and rows synced before this column existed → the runtime falls
  // back to USD formatting.
  currency      String?
  // Raw HTML body from Shopify (descriptionHtml). Source of truth.
  descriptionHtml String?
  // Stripped plain-text version of descriptionHtml — used as input to the
  // Claude tag enrichment so we don't pay tokens on markup.
  descriptionText String?
  // Last time Claude enriched this product's tags. Null = never. The
  // enrichment batch skips products refreshed in the last 30 days.
  lastEnrichedAt DateTime?
  updatedAt     DateTime @default(now()) @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([shopId, handle])
}

model Collection {
  collectionId String   @id
  shopId       String
  title        String
  handle       String?
  productIds   String[]
  updatedAt    DateTime @default(now()) @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
}

// Auto-discovered shopper archetypes. Distinct from Shopify Collections
// (which mirror live store data) — Categories are admin-internal and
// regenerated on demand by Claude reading the catalog. They power the
// archetype branch of the quiz recommendation engine: a ResultPage with
// match_strategy="archetype" + category_id pulls products from here.
model Category {
  id             String   @id @default(cuid())
  shopId         String
  // Phase 2 builder: when a bucket is created inside a quiz's Step-1 product
  // grouping, it's scoped to that quiz. Null = legacy shop-global bucket
  // (the standalone /app/categories page), kept for back-compat.
  quizId         String?
  name           String
  description    String
  // Embodying tags Claude picked from the catalog vocabulary. Used by
  // categoryAssign to score every product's overlap and bucket it.
  tags           String[]
  // Shopify product IDs (gids) bucketed into this category by the
  // deterministic tag-overlap pass OR a non-AI grouping source. Refreshed
  // every grouping/discovery run.
  productIds     String[]
  // v3 grouping on-ramp: how this group was created.
  // "ai" | "manual" | "collection" | "smart_collection" | "tag" |
  // "product_type" | "metafield". Defaults "ai" for existing rows.
  source         String   @default("ai")
  // The dimension value this group came from (collection id / tag /
  // product type / metafield value). Null for manual + ai.
  sourceRef      String?
  // Explicitly pinned product ids in manual mode (productIds is the
  // resolved set; this is the merchant's hand-picked subset).
  manualProductIds String[]
  // P3 Edit 2 — Groups & Personas: mixed-source membership criteria for a group
  // built in the /studio Groups page. Shape (all optional):
  //   { tags: string[], collections: string[], metafields: string[],
  //     manual: string[], persona?: { name, description, image } }
  // Null for legacy single-source categories (source/sourceRef still apply).
  // productIds stays the resolved set (re-resolved from membership on edit).
  membership     Json?
  // One-sentence rationale Claude wrote — surfaced in the admin tooltip.
  rationale      String?
  // Groups every Category created in a single discovery invocation so
  // we can tell when a set was generated.
  discoveryRunId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([shopId, quizId])
}

model Quiz {
  id            String   @id @default(cuid())
  shopId        String
  name          String
  status        String   @default("draft")
  // Transient async-build marker for AI onboarding: "building" while the
  // detached build runs, "error:<msg>" on failure, null when done/normal.
  // Lets the editor poll an overlay instead of blocking the request (the full
  // AI build outruns the edge proxy's ~60s timeout).
  buildState    String?
  draftJson     Json
  publishedJson Json?
  version       Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  shop     Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  versions QuizVersion[]
  events   Event[]
  captures EmailCapture[]
  sessions QuizSession[]
  backInStockRequests BackInStockRequest[]
  feedback QuizFeedback[]
  rewards QuizReward[]
  referralTokens ReferralToken[]
  referrals Referral[]

  @@index([shopId])
}

model QuizVersion {
  id            String   @id @default(cuid())
  quizId        String
  version       Int
  publishedJson Json
  publishedAt   DateTime @default(now())

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@unique([quizId, version])
}

model Event {
  id        String   @id @default(cuid())
  shopId    String?
  quizId    String
  sessionId String
  eventType String
  payload   Json
  ts        DateTime @default(now())

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId, ts])
  @@index([quizId, eventType, ts])
}

// Magic-link login tokens for the standalone /studio surface. One row per
// issued link; stores only the SHA-256 hash of the token (a DB leak yields no
// usable links). Single-use (usedAt) with a short TTL (expiresAt). The email
// is the allowlisted address the link was issued to.
model StudioLoginToken {
  id        String    @id @default(cuid())
  email     String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email, createdAt])
}

model EmailCapture {
  id         String   @id @default(cuid())
  shopId     String?
  quizId     String
  sessionId  String
  email      String
  firstName  String?
  phone      String?
  capturedAt DateTime @default(now())

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId, capturedAt])
  @@index([email])
}

// Rec-Page spec §5 — back-in-stock / "Notify Me" requests captured on the
// result page when a recommended product (or a whole section) is out of stock.
// One row per (shopper email, product). The merchant exports / syncs these to
// their back-in-stock tool; we just durably capture the intent.
model BackInStockRequest {
  id          String   @id @default(cuid())
  shopId      String?
  quizId      String
  sessionId   String?
  productId   String?
  email       String
  requestedAt DateTime @default(now())

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId, requestedAt])
  @@index([email])
}

// §L L2 — post-result feedback ("Was this helpful?"). One submission per session
// (enforced by the unique index). Pseudonymous: keyed by sessionId, no email
// (open text is PII-stripped before egress). Powers quiz-optimization signals.
model QuizFeedback {
  id        String   @id @default(cuid())
  quizId    String
  sessionId String
  rating    Int // thumbs: 1 up / 0 down · stars: 1–5
  text      String?
  outcomeId String?
  createdAt DateTime @default(now())

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@unique([quizId, sessionId])
  @@index([quizId, createdAt])
}

// §M6 — a referrer's public, stable share token (E5, not the session bearer).
// Minted when the referrer completes; a friend redeems with it. `email` is PII.
model ReferralToken {
  id        String   @id @default(cuid())
  token     String   @unique
  quizId    String
  sessionId String
  email     String?
  createdAt DateTime @default(now())

  quiz        Quiz       @relation(fields: [quizId], references: [id], onDelete: Cascade)
  redemptions Referral[]

  @@unique([quizId, sessionId])
  @@index([quizId, createdAt])
}

// §M6 — one redemption (a friend arriving via a referral link). Single-use per
// redeemer. status: pending → qualified (granted at the qualifying order).
// give/get codes are filled when granted. `redeemerEmail` is PII.
model Referral {
  id                String   @id @default(cuid())
  quizId            String
  tokenValue        String
  redeemerSessionId String
  redeemerEmail     String?
  status            String   @default("pending")
  giveCode          String?
  getCode           String?
  createdAt         DateTime @default(now())

  quiz  Quiz          @relation(fields: [quizId], references: [id], onDelete: Cascade)
  token ReferralToken @relation(fields: [tokenValue], references: [token], onDelete: Cascade)

  @@unique([tokenValue, redeemerSessionId])
  @@index([quizId, createdAt])
}

// §M3 — a reward issued to a shopper at result reveal (one per session, E1
// anti-abuse). Stores the created single-use Shopify code so a retry reuses it.
// `email` is shopper PII → covered by GDPR redaction (gdpr.server).
model QuizReward {
  id         String    @id @default(cuid())
  quizId     String
  sessionId  String
  code       String
  rewardType String // percentage | fixed | free_shipping
  value      Float
  email      String?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@unique([quizId, sessionId])
  @@index([quizId, createdAt])
}

// Server-side quiz session (Dev Spec §7.2). One row per (quizId, sessionId):
// the shopper's answers, the products we matched them to, and the outcome page,
// plus a `converted` flag set later by the order webhook. Powers cross-device
// resume + "My Results" + conversion attribution (follow-on slices).
model QuizSession {
  id                String    @id @default(cuid())
  shopId            String?
  quizId            String
  sessionId         String
  outcomeId         String?
  answerIds         String[]
  matchedProductIds String[]
  converted         Boolean   @default(false)
  startedAt         DateTime  @default(now())
  completedAt       DateTime?

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@unique([quizId, sessionId])
  @@index([quizId, completedAt])
}

// BIC-2 A3 — per-shop daily AI token usage, the single source of truth for the
// spend ceilings (app/lib/aiBudget.server.ts). One row per (shopId, UTC day);
// `day` is a "yyyy-mm-dd" string (cleanest upsert key — a @db.Date round-trips
// through JS Date and invites timezone drift on the unique key). Counters are
// atomic upsert-increments; recording is best-effort and NEVER gates a feature.
// No FK to Shop on purpose (the EmailCapture precedent): usage rows are an
// operational ledger, not domain data, and must survive any shop-row churn.
model AiUsage {
  id           String @id @default(cuid())
  shopId       String
  day          String
  inputTokens  Int    @default(0)
  outputTokens Int    @default(0)
  calls        Int    @default(0)

  @@unique([shopId, day])
}

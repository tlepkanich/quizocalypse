{
  "name": "quizocalypse",
  "version": "0.0.1",
  "description": "Shopify-native AI quiz app. M1 (Shopify Connect) + M2 (AI Quiz Generator) PoC.",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "remix vite:build",
    "dev": "shopify app dev",
    "sync-tunnel": "./scripts/sync-tunnel.sh",
    "config:link": "shopify app config link",
    "generate": "shopify app generate",
    "deploy": "shopify app deploy",
    "config:use": "shopify app config use",
    "env": "shopify app env",
    "start": "remix-serve ./build/server/index.js",
    "docker-start": "npm run setup && npm run start",
    "setup": "prisma generate && prisma migrate deploy",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:bless-shots": "SMOKE_SHOTS=1 playwright test e2e/runtime-smoke.spec.ts --update-snapshots",
    "check-tokens": "node scripts/check-tokens.mjs",
    "gen:releases": "node scripts/generate-releases.mjs",
    "shopify": "shopify",
    "prisma": "prisma",
    "graphql-codegen": "graphql-codegen",
    "vite": "vite"
  },
  "engines": {
    "node": ">=20.19"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.32.1",
    "@prisma/client": "6.19.3",
    "@remix-run/dev": "2.17.5",
    "@remix-run/fs-routes": "2.17.5",
    "@remix-run/node": "2.17.5",
    "@remix-run/react": "2.17.5",
    "@remix-run/serve": "2.17.5",
    "@sentry/node": "10.63.0",
    "@shopify/app-bridge-react": "4.2.11",
    "@shopify/polaris": "12.27.0",
    "@shopify/shopify-app-remix": "4.2.0",
    "@shopify/shopify-app-session-storage-prisma": "8.0.1",
    "@types/papaparse": "5.5.2",
    "@xyflow/react": "12.11.1",
    "dagre": "0.8.5",
    "isbot": "5.1.44",
    "lucide-react": "1.23.0",
    "nodemailer": "9.0.3",
    "papaparse": "5.5.4",
    "pino": "10.3.1",
    "prisma": "6.19.3",
    "qrcode": "1.5.4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "vite-tsconfig-paths": "5.1.4",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "1.61.0",
    "@remix-run/eslint-config": "2.17.5",
    "@remix-run/route-config": "2.17.5",
    "@shopify/api-codegen-preset": "1.2.2",
    "@types/dagre": "0.7.54",
    "@types/eslint": "9.6.1",
    "@types/node": "22.20.0",
    "@types/nodemailer": "8.0.1",
    "@types/qrcode": "1.5.6",
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.7",
    "@vitest/coverage-v8": "2.1.9",
    "eslint": "8.57.1",
    "eslint-config-prettier": "10.1.8",
    "jsdom": "29.1.1",
    "prettier": "3.8.4",
    "typescript": "5.9.3",
    "vite": "6.4.3",
    "vitest": "2.1.9"
  },
  "workspaces": {
    "packages": [
      "extensions/*"
    ]
  },
  "trustedDependencies": [
    "@shopify/plugin-cloudflare"
  ],
  "resolutions": {
    "@graphql-tools/url-loader": "8.0.16",
    "@graphql-codegen/client-preset": "4.7.0",
    "@graphql-codegen/typescript-operations": "4.5.0",
    "minimatch": "9.0.5",
    "vite": "6.4.3",
    "@shopify/shopify-api": "^13.0.0",
    "@shopify/shopify-app-session-storage": "^5.0.0"
  },
  "overrides": {
    "@graphql-tools/url-loader": "8.0.16",
    "@graphql-codegen/client-preset": "4.7.0",
    "@graphql-codegen/typescript-operations": "4.5.0",
    "minimatch": "9.0.5",
    "vite": "6.4.3",
    "@shopify/shopify-api": "^13.0.0",
    "@shopify/shopify-app-session-storage": "^5.0.0"
  }
}

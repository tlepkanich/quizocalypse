# Quizocalypse environment. Copy to .env and fill in. NEVER commit real values.
# Every var the app reads is listed here; e2e/probe-only vars are at the bottom.

# ── Core (required) ──────────────────────────────────────────────────────────

# Postgres. Local: `createdb quizocalypse_dev`.
# NOTE: the local DB is NOT the deploy DB — fixtures never cross environments.
DATABASE_URL=postgresql://localhost:5432/quizocalypse_dev?schema=public

# Anthropic API key — powers all AI generation (funnel, edits, rec copy).
ANTHROPIC_API_KEY=sk-ant-your-key-here

# 32 bytes hex (64 chars) for AES-256-GCM at-rest encryption.
# Generate: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# ── Shopify (embedded /app surface) ──────────────────────────────────────────
# Populated by `npm run config:link` + `npm run dev` (Shopify CLI).
# DELIBERATELY EMPTY for standalone/local-prod work: when starting a local
# prod server, pass inline placeholders instead of filling these in —
#   SHOPIFY_API_KEY=x SHOPIFY_API_SECRET=x SHOPIFY_APP_URL=http://localhost:3000 npm run start
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=
SCOPES=read_products,read_inventory,write_discounts,read_themes
# Optional: only for shops on a custom (non-myshopify.com) domain.
# SHOP_CUSTOM_DOMAIN=shop.example.com

# ── Standalone /studio surface ────────────────────────────────────────────────

# Signs the studio session cookie (magic-link auth). Falls back to
# STUDIO_ACCESS_TOKEN when unset. Generate: openssl rand -hex 24
STUDIO_SESSION_SECRET=

# LEGACY break-glass: /studio?key=<token> sets an access cookie directly.
# Kept while magic-link auth is confirmed for all users; removal is owner-gated.
# Never print or log this value. Generate: openssl rand -hex 24
STUDIO_ACCESS_TOKEN=

# Comma-separated allowlist for magic-link login emails.
STUDIO_ALLOWED_EMAILS=owner@example.com,teammate@example.com

# Magic-link email delivery: Resend preferred; Gmail SMTP as fallback
# (Resend's sandbox only delivers to its own account owner).
RESEND_API_KEY=
# STUDIO_EMAIL_FROM=Quizocalypse Studio <login@example.com>
# GMAIL_SMTP_USER=you@gmail.com
# GMAIL_SMTP_APP_PASSWORD=your-gmail-app-password

# The installed dev store the standalone surface manages (must match a Shop
# row created via Shopify OAuth). Ignored when STUDIO_MODE=standalone.
DEV_SHOP_DOMAIN=your-store.myshopify.com

# Optional: "standalone" = non-Shopify workspace (no dev store, no Shopify calls).
# STUDIO_MODE=standalone

# ── Observability (optional — code is live but dormant until set) ────────────

# Sentry error tracking. Unset = no-op.
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# pino log level (fatal|error|warn|info|debug|trace). Default: info.
# LOG_LEVEL=info

# ── AI spend ceilings (optional; per-shop, per-UTC-day) ──────────────────────
# Defaults: runtime=2, merchant=10. Explicit 0 = enforcement OFF for that surface.

# Public shopper surface (POST /q/:id/rec-copy) — the tightest ceiling.
# AI_BUDGET_RUNTIME_DAILY_USD=2
# Merchant-invoked AI (funnel generation, why-copy, path-quality, edits).
# AI_BUDGET_MERCHANT_DAILY_USD=10

# ── Runtime/platform (usually NOT set by hand) ────────────────────────────────
# PORT           — server port (default 3000; Fly sets it).
# HOST           — set by the Shopify CLI dev tunnel (vite.config maps it to SHOPIFY_APP_URL).
# FRONTEND_PORT  — Shopify CLI dev HMR port (default 8002).
# FLY_APP_NAME   — set by Fly; used as the Sentry environment name.
# NODE_ENV       — set by the tooling.

# ── e2e / probe vars (shell-only; never needed in .env for the app itself) ───
# SMOKE_BASE       — e2e target base URL (default: the live deploy).
# SMOKE_QUIZZES / SMOKE_PP_QUIZ / SMOKE_RT_QUIZ — fixture overrides (see e2e/README.md).
# SMOKE_SHOTS=1    — enable screenshot regression asserts (darwin baselines only).
# RT_LOCAL=1 / RT_BOOTSTRAP=1 — round-trip spec modes (see e2e/README.md).
# BASE             — probe-script target (default http://localhost:3000).
# SKIP_REAL_GEN=1  — a3-budget probe: skip the real-AI generation step.
